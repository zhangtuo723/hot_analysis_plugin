{
  "manifest_version": 3,
  "name": "小红书爆款分析",
  "version": "0.3.0",
  "description": "对话式小红书爆款分析助手，AI Agent 自动操作浏览器抓取数据并分析爆款规律",
  "permissions": ["activeTab", "tabs", "scripting", "storage"],
  "host_permissions": ["https://www.xiaohongshu.com/*"],
  "action": {
    "default_title": "小红书爆款分析",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.xiaohongshu.com/*"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
